# Compiled artifacts
/target/
**/target/

# Generated by Cargo
**/Cargo.lock

# If using Rust Analyzer or rls caches
/.idea/
/.vscode/
*.swp
*.swo
*.sublime-*

# Editor/IDE
*.rs.bk
*.log

# OS files
.DS_Store
Thumbs.db

# Backup files
*~

# Binaries
/*.exe
/*.dll
/*.so
/*.dylib

# Test output and coverage
/coverage/
/htmlcov/
/*.prof

# Docs build
/book/
/target/doc/

# Credential files
.env
.env.*

# Ignore build artifacts from examples/benchmarks if produced elsewhere
/examples/*/target/

# Optional: ignore node_modules if using wasm-pack + npm in the project
node_modules/
pkg/
